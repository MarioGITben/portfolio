# Copy to ".env" for local dev. On Vercel/Netlify/Cloudflare, add these under Environment variables and redeploy.
# Create a template at https://www.emailjs.com — use variables: {{from_name}}, {{from_email}}, {{message}}
# In EmailJS: Account → Security → Allowed list (restrict to your production domain).

VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
